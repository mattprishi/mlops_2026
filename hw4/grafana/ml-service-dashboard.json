      "title": "Технические метрики",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Скорость запросов по HTTP-кодам ответа. Позволяет отслеживать долю ошибок (4xx/5xx). Ось Y: запросов в секунду (RPS).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "RPS",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "title": "HTTP: RPS по коду ответа",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Квантили задержки полного HTTP-запроса (middleware). Summary из prometheus_client. Ось Y: секунды.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "секунды",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "max(http_request_duration_seconds{quantile=\"0.75\"})",
          "legendFormat": "p75",
          "refId": "A"
        },
        {
          "expr": "max(http_request_duration_seconds{quantile=\"0.9\"})",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "max(http_request_duration_seconds{quantile=\"0.95\"})",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "expr": "max(http_request_duration_seconds{quantile=\"0.99\"})",
          "legendFormat": "p99",
          "refId": "D"
        },
        {
          "expr": "max(http_request_duration_seconds{quantile=\"0.999\"})",
          "legendFormat": "p99.9",
          "refId": "E"
        }
      ],
      "title": "HTTP: задержка (квантили)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Потребление резидентной памяти процессом uvicorn (ProcessCollector). Ось Y: байты.",
      "fieldConfig": {
        "defaults": {
          "custom": {"axisLabel": "память", "drawStyle": "line", "fillOpacity": 20},
